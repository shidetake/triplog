{
  "mcpServers": {
    "gmail": {
      "command": "npx",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"]
    },
    "gsheets": {
      "command": "npx",
      "args": ["-y", "mcp-google-sheets@2.0.1"],
      "env": {
        "CREDENTIALS_PATH": "${HOME}/.config/gcloud/travel-expenses-oauth.json",
        "TOKEN_PATH": "${HOME}/.config/gcloud/triplog-sheets-token.json"
      }
    }
  }
}
